<!DOCTYPE html>
<html>
<head>
  <title><%= title %> - Last 7 Days</title>
  <!-- Shared base styles -->
  <%- include('./partials/styles-base') %>
  
    <!-- Page-specific styles -->
  <style>
    body {
      margin: 40px;
    }

    h1 {
      margin-bottom: 10px;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(350px, 1fr));
      gap: 20px;
    }

    .project-card {
      background: var(--card-bg);
      padding: 20px;
      border-radius: var(--border-radius-sm);
      border-left: 4px solid var(--color-primary);
      box-shadow: var(--card-shadow);
    }
  </style>
</head>
<body>
  <div class="container">
    <% if (error) { %>
      <div class="error">
        <h1>Error</h1>
        <p><%= error %></p>
        <a href="/">← Back to popular feeds</a>
      </div>
    <% } else { %>
      <h1><a href="https://bsky.app/profile/<%= hostname %>/feed/<%= feedKey %>" target="_blank"><%= title %></a></h1>
      <p class="subtitle">
        <%= description %><br>
        Projects mentioned in the last 7 days (since <%= fromDate %>)
      </p>
      
      <% if (projects && projects.length > 0) { %>
        <div class="projects-grid">
          <% projects.forEach(function(project) { %>
            <div class="project-card">
              <h3 class="project-title"><%= project.title %></h3>
              <div class="project-meta">
                <%= project.category %>
                <% if (project.parentCategory) { %>
                  (<%= project.parentCategory %>)
                <% } %>
              </div>
              <% if (project.details && project.details['blurb']) { %>
                <div class="project-blurb"><%= project.details['blurb'] %></div>
              <% } %>
               <div class="project-stats">
                 <a href="/project/<%= project.projectId %>" class="post-count"><%= project.postCount %> posts</a>
                 <a href="<%= project.uri %>" target="_blank" class="view-link">View Project ↗</a>
               </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="no-data">
          <h3>No projects found</h3>
          <p>No projects have been mentioned in this feed in the last 7 days.</p>
        </div>
      <% } %>
    <% } %>
  </div>
</body>
</html>
