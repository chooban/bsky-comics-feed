<!DOCTYPE html>
<html>
<head>
  <title>
    <%= title %> - Posts
  </title>
  
  <!-- Bluesky embed links -->
  <%- include('./partials/embed-links') %>
  
  <!-- Shared base styles -->
  <%- include('./partials/styles-base') %>
  
  <!-- Page-specific styles -->
  <style>
    body {
      margin: 0;
      padding: 20px;
    }

    .container {
      max-width: 800px;
      margin: 0 auto;
    }

    .posts-list {
      display: flex;
      flex-direction: column;
      gap: 30px;
    }

    .post-item {
      background: var(--card-bg);
      padding: 20px;
      border-radius: var(--border-radius-sm);
      box-shadow: var(--card-shadow);
    }

    .post-meta {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid var(--color-border);
    }

    .post-author {
      color: var(--color-dark);
      font-weight: 500;
      text-decoration: none;
    }

    .post-author:hover {
      color: var(--color-primary);
    }

    .post-embed {
      margin: 15px 0;
    }

    .top-posters {
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 1px solid var(--color-border);
    }

    .top-posters-label {
      margin: 0 0 10px 0;
      font-size: 12px;
      font-weight: 600;
      color: var(--color-gray-medium);
      text-transform: uppercase;
      letter-spacing: 0.5px;
    }

    .poster-badges {
      display: flex;
      flex-wrap: wrap;
      gap: 8px;
    }

    .poster-badge {
      display: inline-flex;
      align-items: center;
      gap: 6px;
      padding: 6px 12px;
      background: var(--color-gray-light);
      color: var(--color-dark);
      text-decoration: none;
      border-radius: var(--border-radius-lg);
      font-size: 13px;
      font-weight: 500;
      border: 1px solid transparent;
    }

    .poster-badge:hover {
      background: var(--color-primary);
      color: white;
      border-color: #2980b9;
    }

    .poster-badge .post-count {
      background: rgba(0, 0, 0, 0.15);
      padding: 2px 6px;
      border-radius: 10px;
      font-size: 12px;
      font-weight: 600;
    }

    .poster-badge:hover .post-count {
      background: rgba(255, 255, 255, 0.3);
    }

    .poster-avatar {
      width: 20px;
      height: 20px;
      border-radius: 50%;
      object-fit: cover;
    }
  </style>
</head>
<body>
  <div class="container">
    <% if (error) { %>
      <div class="error">
        <h1>Error</h1>
        <p><%= error %></p>
        <a href="/" class="back-link">← Back to home</a>
      </div>
     <% } else { %>
      <div class="header">
         <h1><a href="https://bsky.app/profile/<%= hostname %>/post/<%= projectUri %>" target="_blank"><%= title %></a></h1>
         <div class="project-meta">
          <%= category %>
          <% if (parentCategory) { %>
            (<%= parentCategory %>)
          <% } %>
        </div>
        <% if (description) { %>
          <div class="project-description"><%= description %></div>
        <% } %>
        <div class="posts-count">
          <% if (postCount === 0) { %>
            No posts about this project
          <% } else if (postCount === 1) { %>
            1 post
          <% } else { %>
            <%= postCount %> posts
          <% } %>
        </div>
        <a href="/" class="back-link">← Back to home</a>
      </div>
      <% if (topPosters && topPosters.length> 0) { %>
        <div class="post-item" style="margin-bottom: 2rem;">
          <div class="top-posters">
            <h4 class="top-posters-label">Top Posters</h4>
            <div class="poster-badges">
              <% topPosters.forEach(function(poster) { %>
                <a href="https://bsky.app/profile/<%= poster.profile.handle %>" target="_blank" class="poster-badge">
                  <% if (poster.profile.avatar) { %>
                    <img src="<%= poster.profile.avatar %>" alt="<%= poster.profile.handle %>" class="poster-avatar">
                    <% } %>
                      @<%= poster.profile.handle %>
                        <span class="post-count">
                          <%= poster.postCount %>
                        </span>
                </a>
                <% }) %>
            </div>
          </div>
        </div>
        <% } %>
      <% if (posts && posts.length > 0) { %>
        <div class="posts-list">
          <% posts.forEach(function(post) { %>
            <div class="post-item">
              <div class="post-meta">
                <!-- <a href="https://bsky.app/profile/<%= post.author %>" class="post-author" target="_blank">@<%= post.author %></a> -->
                <span class="post-date"><%= new Date(post.createdAt).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric', hour: '2-digit', minute: '2-digit' }) %></span>
              </div>
              <div class="post-embed">
                <bluesky-post src="<%= post.atUri %>">
                  <blockquote class="bluesky-post-fallback">
                    <a href="<%= post.bskyUrl %>">View on Bluesky</a>
                  </blockquote>
                </bluesky-post>

              </div>
            </div>
          <% }) %>
        </div>
      <% } else { %>
        <div class="no-posts">
          <h3>No posts yet</h3>
          <p>No one has posted about this project yet.</p>
        </div>
      <% } %>
    <% } %>
  </div>
</body>
</html>
