<!DOCTYPE html>
<html>
<head>
  <title>Popular Kickstarter Projects - Last 7 Days</title>
  <!-- Shared base styles -->
  <%- include('./partials/styles-base') %>
  
    <!-- Page-specific styles -->
  <style>
    body {
      margin: 40px;
    }

    h1 {
      margin-bottom: 30px;
    }

    .subtitle {
      font-size: 18px;
    }

    .category-section {
      background: var(--card-bg);
      padding: 25px;
      margin-bottom: 30px;
      border-radius: var(--border-radius-md);
      box-shadow: var(--card-shadow);
    }

    .category-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 20px;
      padding-bottom: 15px;
      border-bottom: 2px solid var(--color-primary);
    }

    .category-title {
      font-size: 24px;
      color: var(--color-dark);
      margin: 0;
    }

    .category-title a {
      color: var(--color-dark);
      text-decoration: none;
    }

    .category-title a:hover {
      color: var(--color-primary);
      text-decoration: underline;
    }

    .category-count {
      color: var(--color-gray-medium);
      font-size: 16px;
    }

    .view-all-link {
      color: var(--color-primary);
      text-decoration: none;
      font-size: 14px;
      font-weight: 500;
    }

    .view-all-link:hover {
      text-decoration: underline;
    }

    .projects-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 20px;
    }

    .project-card {
      background: var(--color-gray-light);
      padding: 20px;
      border-radius: var(--border-radius-sm);
      border-left: 4px solid var(--color-primary);
      transition: transform 0.2s;
    }

    .project-card:hover {
      transform: translateY(-2px);
      box-shadow: var(--shadow-md);
    }

    .loading {
      text-align: center;
      padding: 60px;
      color: var(--color-gray-dark);
    }
  </style>
</head>
<body>
  <div class="container">
    <h1>Popular Kickstarter Projects</h1>
    <p class="subtitle">
      Top categories and projects from the last 7 days (since <%= fromDate %>)
    </p>
    
    <% if (categories && categories.length > 0) { %>
      <% categories.forEach(function(category) { %>
        <div class="category-section">
          <div class="category-header">
            <h2 class="category-title"><a href="https://bsky.app/profile/<%= hostname %>/feed/<%= category.feedKey %>" target="_blank"><%= category.title %></a></h2>
            <span class="category-count"><%= category.postCount %> posts</span>
            <a href="/feed/<%= category.feedKey %>" class="view-all-link">View All Projects →</a>
          </div>
          <div class="projects-grid">
            <% category.topProjects.forEach(function(project) { %>
              <div class="project-card">
                <h3 class="project-title"><%= project.title %></h3>
                <div class="project-blurb"><%= project.details?.['blurb'] %></div>
                <div class="project-stats">
                  <span class="post-count"><%= project.postCount %> posts</span>
                  <a href="<%= project.uri %>" target="_blank" class="view-link">View Project ↗</a>
                </div>
              </div>
            <% }) %>
          </div>
        </div>
      <% }) %>
    <% } else { %>
      <div class="loading">
        No data available for the selected time period.
      </div>
    <% } %>
  </div>
</body>
</html>
